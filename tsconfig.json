{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "node",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "outDir": "./.vercel/output/functions",  
    "rootDir": "./",
    "jsx": "preserve",
    "declaration": false,
    "sourceMap": false
  },
  "include": ["api/**/*.ts"],
  "exclude": ["node_modules"]
}
